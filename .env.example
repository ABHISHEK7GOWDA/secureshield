# SecureShield AI - Environment Configuration Template

# Server Port
PORT=4173
NODE_ENV=development

# Database Connections
MONGODB_URI=mongodb://127.0.0.1:27017/secureshield
REDIS_URI=redis://127.0.0.1:6379

# Cryptographic Keys (Change in Production!)
ACCESS_TOKEN_SECRET=secureshield_dev_access_token_secret_string_2026!
REFRESH_TOKEN_SECRET=secureshield_dev_refresh_token_secret_string_2026!

# --- SMS Providers (Configure to send live SMS OTPs) ---
# Fast2SMS API Key
FAST2SMS_API_KEY=

# Twilio Account details
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Email Provider (Configure to send live Email OTPs) ---
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=secureshield.test@ethereal.email
SMTP_PASS=secureshieldPassword123
